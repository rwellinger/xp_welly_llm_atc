{
  "_comment": "IFR-specific flight rules — merged with eu/vfr/flight_rules.json at load time. Object keys extend (never override) VFR entries; arrays are appended.",

  "ifr_defaults": {
    "_comment": "Consumed by build_vars() via flight_phase::ifr_defaults(). initial_altitude_ft is the default climb clearance limit when no ATC-assigned level is available.",
    "initial_altitude_ft": 5000,
    "squawk_range_min": 1001,
    "squawk_range_max": 6776
  },

  "intent_preconditions": {
    "REQUEST_IFR_CLEARANCE": {
      "allowed_phases": ["PARKED", "TAXI"],
      "rejection_airborne": "{callsign}, unable, you are already airborne."
    },
    "REQUEST_STARTUP": {
      "allowed_phases": ["PARKED", "TAXI"],
      "rejection_airborne": "{callsign}, unable, startup not applicable airborne."
    }
  },

  "intent_frequency": {
    "REQUEST_IFR_CLEARANCE": {
      "allowed": ["DELIVERY", "GROUND"],
      "rejection": "{callsign}, contact Delivery for IFR clearance."
    },
    "REQUEST_STARTUP": {
      "allowed": ["DELIVERY", "GROUND"],
      "rejection": "{callsign}, contact Delivery or Ground for startup."
    },
    "READBACK": {
      "allowed": ["DELIVERY"]
    },
    "RADIO_CHECK": {
      "allowed": ["DELIVERY"]
    }
  },

  "state_frequency_validity": {
    "DELIVERY": ["IDLE", "IFR/PREDEP_CLEARANCE", "IFR/CLEARED"],
    "GROUND":   ["IFR/PREDEP_CLEARANCE", "IFR/CLEARED"],
    "TOWER":    ["IFR/CLEARED", "IFR/DEPARTURE_CLEARED", "IFR/EN_ROUTE"]
  },

  "auto_corrections": {
    "IFR/PREDEP_CLEARANCE": {
      "on_airborne": {
        "phases": ["TAKEOFF_ROLL", "CLIMB", "PATTERN", "FINAL_APPROACH", "CRUISE"],
        "next_state": "IDLE",
        "delay_sec": 5.0
      }
    },
    "IFR/CLEARED": {
      "on_airborne": {
        "phases": ["TAKEOFF_ROLL", "CLIMB", "PATTERN", "FINAL_APPROACH", "CRUISE"],
        "next_state": "IDLE",
        "delay_sec": 5.0
      }
    },
    "IFR/DEPARTURE_CLEARED": {
      "on_airborne": {
        "phases": ["CLIMB", "CRUISE"],
        "next_state": "IFR/EN_ROUTE",
        "delay_sec": 10.0
      }
    },
    "IFR/EN_ROUTE": {
      "on_ground": {
        "phases": ["PARKED", "TAXI"],
        "next_state": "IDLE",
        "delay_sec": 30.0
      }
    }
  },

  "pilot_phraseology": {
    "REQUEST_IFR_CLEARANCE": "{airport} Delivery, {callsign}{aircraft_type_phrase}, request IFR clearance to {ifr_destination}, information {atis_letter}",
    "REQUEST_STARTUP": "{airport} Ground, {callsign}, request startup",
    "READY_FOR_DEPARTURE_IFR": "{airport} Tower, {callsign}, holding point runway {runway}, ready for departure IFR to {ifr_destination}"
  }
}
