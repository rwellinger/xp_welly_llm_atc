{
  "_comment": "ATC response templates organized by airport type (towered/uncontrolled), ATC state, and pilot intent. Each entry defines: response (template text with {variable} placeholders), next_state (state machine transition), and requires_readback (whether the pilot must read back the clearance). The _INVALID key is the fallback when no matching intent is found for the current state. Variables are filled at runtime by atc_state_machine::build_vars() from XPlaneContext data.",
  "towered": {
    "IDLE": {
      "INITIAL_CALL_GROUND": {
        "response": "{callsign}, {airport} Ground, {position_remark}information {atis_letter} current, runway {runway}, QNH {qnh}.",
        "next_state": "GROUND_CONTACT",
        "requires_readback": false
      },
      "INITIAL_CALL_TOWER": {
        "response": "{callsign}, {airport} Tower, go ahead.",
        "next_state": "TOWER_CONTACT",
        "requires_readback": false
      },
      "INITIAL_CALL_INBOUND": {
        "response": "{callsign}, {airport} Tower, enter {pattern_direction} downwind runway {runway}, report midfield downwind.",
        "next_state": "PATTERN_ENTRY",
        "requires_readback": true
      },
      "INITIAL_CALL_INBOUND_VRP": {
        "response": "{callsign}, {airport} Tower, cleared to enter control zone via {entry_vrp}, runway {runway}, report {pattern_direction} downwind.",
        "next_state": "PATTERN_ENTRY",
        "requires_readback": true
      },
      "REQUEST_TAXI": {
        "response": "{callsign}, {airport} Ground, {position_remark}information {atis_letter} current, taxi to holding point runway {runway} via Alpha, QNH {qnh}.",
        "next_state": "TAXI_CLEARED",
        "requires_readback": true
      },
      "REQUEST_TAXI_PARKING": {
        "response": "{callsign}, {airport} Ground, taxi to general aviation parking via Alpha.",
        "next_state": "IDLE",
        "requires_readback": true
      },
      "READBACK": {
        "response": "",
        "next_state": "IDLE",
        "requires_readback": false
      },
      "READY_FOR_DEPARTURE": {
        "response": "{callsign}, {airport} Tower, runway {runway}, cleared for takeoff, wind {wind}, report {pattern_direction} downwind.",
        "next_state": "DEPARTURE_CLEARED",
        "requires_readback": true
      },
      "READY_FOR_DEPARTURE_VFR": {
        "response": "{callsign}, {airport} Tower, runway {runway}, cleared for takeoff, wind {wind}, on course approved, frequency change approved when airborne.",
        "next_state": "DEPARTURE_CLEARED",
        "requires_readback": true
      },
      "RADIO_CHECK": {
        "response": "{callsign}, {airport} Tower, reading you five by five.",
        "next_state": "IDLE",
        "requires_readback": false
      },
      "INITIAL_CALL_APPROACH": {
        "response": "{callsign}, {airport} Approach, pass your message.",
        "next_state": "APPROACH_CONTACT",
        "requires_readback": false
      },
      "RUNWAY_VACATED": {
        "response": "{callsign}, roger, contact ground on {ground_frequency}, good day.",
        "next_state": "IDLE",
        "requires_readback": false
      },
      "_INVALID": {
        "response": "{callsign}, say again your request.",
        "next_state": "IDLE",
        "requires_readback": false
      }
    },
    "GROUND_CONTACT": {
      "REQUEST_TAXI": {
        "response": "{callsign}, taxi to holding point runway {runway} via Alpha, QNH {qnh}.",
        "next_state": "TAXI_CLEARED",
        "requires_readback": true
      },
      "READBACK": {
        "response": "{callsign}, readback correct.",
