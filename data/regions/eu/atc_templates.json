    "TRAFFIC_DIALOG": {
      "_comment": "Phase-2 traffic dialog. Side-channel parallel to the main ATCState flow — entries here are rendered exclusively by traffic_dialog and atc_state_machine::render_traffic_advisory(). next_state values are unused (traffic_dialog owns its own state); kept for template-engine schema compatibility.",
      "traffic_advisory": {
        "response": "{callsign}, traffic, {clock} o'clock, {distance} miles, {direction}, {altitude_info}, {type}.",
        "next_state": "IDLE",
        "requires_readback": false
